{
  "type": "xypdf",
  "description": "Disable a FreeIPA user and remove the same user's public SSH key from multiple hosts",
  "version": "1.0",
  "xyops": "1.0.83",
  "items": [
    {
      "type": "event",
      "data": {
        "id": "efreeipadisablekey",
        "title": "Отключить пользователя FreeIPA → удалить SSH-ключ на хостах",
        "enabled": true,
        "targets": [],
        "params": {},
        "fields": [
          {
            "id": "ipa_url",
            "title": "URL FreeIPA",
            "type": "text",
            "variant": "url",
            "value": "https://ipa.example.local",
            "required": true
          },
          {
            "id": "ca_cert_path",
            "title": "Сертификат CA FreeIPA",
            "type": "text",
            "value": "/etc/ipa/ca.crt",
            "required": false
          },
          {
            "id": "insecure_tls",
            "title": "Отключить проверку TLS FreeIPA",
            "type": "checkbox",
            "value": false
          },
          {
            "id": "uid",
            "title": "Логин пользователя",
            "type": "text",
            "value": "",
            "required": true
          },
          {
            "id": "ssh_public_key",
            "title": "Открытый SSH-ключ для удаления",
            "type": "textarea",
            "value": "",
            "required": true,
            "caption": "Вставьте публичный ключ пользователя одной строкой. Комментарий ключа может отличаться от записи на сервере."
          },
          {
            "id": "ssh_hosts",
            "title": "SSH-адреса и порты",
            "type": "textarea",
            "value": "192.168.1.10:22\n192.168.1.11:2222",
            "required": true,
            "caption": "По одному host:port на строку."
          }
        ],
        "triggers": [
          {
            "enabled": true,
            "type": "manual",
            "id": "ndisabletrig1"
          }
        ],
        "limits": [
          {
            "type": "job",
            "enabled": true,
            "amount": 1
          },
          {
            "type": "queue",
            "enabled": true,
            "amount": 0
          },
          {
            "type": "retry",
            "enabled": true,
            "amount": 0,
            "duration": 0
          }
        ],
        "actions": [],
        "notes": "Сначала отключает пользователя в FreeIPA. Только после успеха удаляет указанный публичный ключ из authorized_keys локального пользователя на каждом SSH-хосте. Локальная учётная запись, пароль, sudo и остальные ключи сохраняются.",
        "workflow": {
          "nodes": [
            {
              "id": "ndisabletrig1",
              "type": "trigger",
              "x": -120,
              "y": 240
            },
            {
              "id": "ndisableipa1",
              "type": "job",
              "x": 100,
              "y": 160,
              "data": {
                "params": {
                  "ipa_url": "{{ workflow.params.ipa_url }}",
                  "ca_cert_path": "{{ workflow.params.ca_cert_path }}",
                  "timeout_seconds": "30",
                  "insecure_tls": "{{ workflow.params.insecure_tls }}",
                  "uid": "{{ workflow.params.uid }}",
                  "freeipa_tool": "disableUser",
                  "action": "disable_user"
                },
                "targets": [
                  "main"
                ],
                "algo": "random",
                "label": "Отключить пользователя FreeIPA",
                "category": "general",
                "plugin": "pmlc2ha8fipa1",
                "icon": "account-cancel-outline",
                "tags": []
              }
            },
            {
              "id": "nsplitdisable1",
              "type": "controller",
              "x": 390,
              "y": 240,
              "data": {
                "controller": "split",
                "split": "workflow.params.ssh_hosts",
                "continue": 100
              }
            },
            {
              "id": "nremovekey01",
              "type": "job",
              "x": 650,
              "y": 160,
              "data": {
                "params": {
                  "action": "ssh_remove_user_key",
                  "host_port": "{{ data.item }}",
                  "username": "{{ workflow.params.uid }}",
                  "public_key": "{{ workflow.params.ssh_public_key }}",
                  "connect_timeout_seconds": "15",
                  "strict_host_key": false,
                  "host_fingerprint": ""
                },
                "targets": [
                  "main"
                ],
                "algo": "random",
                "label": "Удалить публичный SSH-ключ",
                "category": "general",
                "plugin": "pmlc2ha8fssh_key_remove",
                "icon": "key-remove",
                "tags": []
              }
            }
          ],
          "connections": [
            {
              "id": "cstartdisable",
              "source": "ndisabletrig1",
              "dest": "ndisableipa1"
            },
            {
              "id": "cdisablesplit",
              "source": "ndisableipa1",
              "dest": "nsplitdisable1",
              "condition": "success"
            },
            {
              "id": "csplitremovekey",
              "source": "nsplitdisable1",
              "dest": "nremovekey01"
            }
          ]
        },
        "category": "general",
        "type": "workflow",
        "icon": "account-off-outline",
        "tags": [],
        "plugin": "_workflow",
        "username": "admin",
        "revision": 1
      }
    }
  ]
}
