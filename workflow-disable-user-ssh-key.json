{
  "type": "xypdf",
  "description": "Workflow отключает пользователя FreeIPA и после успешного результата удаляет файл authorized_keys одноимённого локального пользователя на всех указанных SSH-хостах.",
  "version": "1.0",
  "xyops": "1.0.83",
  "items": [
    {
      "type": "event",
      "data": {
        "id": "efreeipadisablekey",
        "title": "Отключить пользователя FreeIPA → удалить все SSH-ключи на хостах",
        "enabled": true,
        "targets": [],
        "params": {},
        "fields": [
          {
            "id": "ipa_url",
            "title": "URL FreeIPA",
            "type": "text",
            "variant": "url",
            "value": "https://ipa.example.local",
            "required": true,
            "caption": "Базовый HTTPS-адрес FreeIPA."
          },
          {
            "id": "ca_cert_path",
            "title": "Сертификат CA FreeIPA",
            "type": "text",
            "value": "/etc/ipa/ca.crt",
            "required": false,
            "caption": "Путь к CA-сертификату на xySat; можно использовать IPA_CA_CERT_PATH из Secret Vault."
          },
          {
            "id": "insecure_tls",
            "title": "Отключить проверку TLS FreeIPA",
            "type": "checkbox",
            "value": false,
            "caption": "Только для диагностики. В production оставляйте выключенным."
          },
          {
            "id": "uid",
            "title": "Логин пользователя",
            "type": "text",
            "value": "",
            "required": true,
            "caption": "Один логин используется для отключения FreeIPA и поиска локального пользователя на нодах."
          },
          {
            "id": "ssh_hosts",
            "title": "SSH-адреса и порты",
            "type": "textarea",
            "value": "192.168.1.10:22\n192.168.1.11:2222",
            "required": true,
            "caption": "По одному host:port на строку. SSH-шаги выполняются только после успешного отключения FreeIPA."
          }
        ],
        "triggers": [
          {
            "enabled": true,
            "type": "manual",
            "id": "ndisabletrig1"
          }
        ],
        "limits": [
          {
            "type": "job",
            "enabled": true,
            "amount": 1
          },
          {
            "type": "queue",
            "enabled": true,
            "amount": 0
          },
          {
            "type": "retry",
            "enabled": true,
            "amount": 0,
            "duration": 0
          }
        ],
        "actions": [],
        "notes": "Сценарий отключения доступа: сначала отключает пользователя в FreeIPA, затем удаляет весь ~/.ssh/authorized_keys одноимённого локального пользователя на каждой ноде. Локальная учётная запись, пароль, home и sudo сохраняются; активные SSH-сессии не завершаются, вход по паролю отдельно не блокируется. Требует FreeIPA- и SSH-секреты.",
        "workflow": {
          "nodes": [
            {
              "id": "ndisabletrig1",
              "type": "trigger",
              "x": -120,
              "y": 240
            },
            {
              "id": "ndisableipa1",
              "type": "job",
              "x": 100,
              "y": 160,
              "data": {
                "params": {
                  "ipa_url": "{{ workflow.params.ipa_url }}",
                  "ca_cert_path": "{{ workflow.params.ca_cert_path }}",
                  "timeout_seconds": "30",
                  "insecure_tls": "{{ workflow.params.insecure_tls }}",
                  "uid": "{{ workflow.params.uid }}",
                  "freeipa_tool": "disableUser",
                  "action": "disable_user"
                },
                "targets": [
                  "main"
                ],
                "algo": "random",
                "label": "Отключить пользователя FreeIPA",
                "category": "general",
                "plugin": "pmlc2ha8fipa1",
                "icon": "account-cancel-outline",
                "tags": []
              }
            },
            {
              "id": "nsplitdisable1",
              "type": "controller",
              "x": 390,
              "y": 240,
              "data": {
                "controller": "split",
                "split": "workflow.params.ssh_hosts",
                "continue": 100
              }
            },
            {
              "id": "nremovekey01",
              "type": "job",
              "x": 650,
              "y": 160,
              "data": {
                "params": {
                  "action": "ssh_remove_user_key",
                  "host_port": "{{ data.item }}",
                  "username": "{{ workflow.params.uid }}",
                  "connect_timeout_seconds": "15",
                  "strict_host_key": false,
                  "host_fingerprint": ""
                },
                "targets": [
                  "main"
                ],
                "algo": "random",
                "label": "Удалить все публичные SSH-ключи",
                "category": "general",
                "plugin": "pmlc2ha8fssh_key_remove",
                "icon": "key-remove",
                "tags": []
              }
            }
          ],
          "connections": [
            {
              "id": "cstartdisable",
              "source": "ndisabletrig1",
              "dest": "ndisableipa1"
            },
            {
              "id": "cdisablesplit",
              "source": "ndisableipa1",
              "dest": "nsplitdisable1",
              "condition": "success"
            },
            {
              "id": "csplitremovekey",
              "source": "nsplitdisable1",
              "dest": "nremovekey01"
            }
          ]
        },
        "category": "general",
        "type": "workflow",
        "icon": "account-off-outline",
        "tags": [],
        "plugin": "_workflow",
        "username": "admin",
        "revision": 2
      }
    }
  ]
}
