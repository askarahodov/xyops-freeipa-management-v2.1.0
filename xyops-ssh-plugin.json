{
  "type": "xypdf",
  "description": "SSH local-user management plugins",
  "version": "1.0",
  "xyops": "1.0.83",
  "items": [
    {
      "type": "plugin",
      "data": {
        "id": "pmlc2ha8fssh_user",
        "title": "SSH — Создать локального пользователя",
        "enabled": true,
        "type": "event",
        "command": "npx -y github:askarahodov/xyops-freeipa-management-v2.1.0#main",
        "script": "",
        "groups": [],
        "format": "",
        "params": [
          {
            "id": "action",
            "title": "Action",
            "type": "hidden",
            "value": "ssh_provision_user"
          },
          {
            "id": "host_port",
            "title": "Адрес и порт",
            "type": "text",
            "value": "",
            "required": true
          },
          {
            "id": "username",
            "title": "Логин пользователя",
            "type": "text",
            "value": "",
            "required": true
          },
          {
            "id": "user_password",
            "title": "Пароль пользователя",
            "type": "text",
            "variant": "password",
            "value": "",
            "required": true
          },
          {
            "id": "public_key",
            "title": "Открытый SSH-ключ пользователя",
            "type": "textarea",
            "value": "",
            "required": true,
            "caption": "Одна строка публичного ключа: ssh-ed25519, ssh-rsa или ecdsa."
          },
          {
            "id": "grant_sudo",
            "title": "Разрешить sudo и sudo su",
            "type": "checkbox",
            "value": true
          },
          {
            "id": "passwordless_sudo",
            "title": "Sudo без пароля",
            "type": "checkbox",
            "value": false,
            "caption": "Если выключено, sudo запросит пароль создаваемого пользователя."
          },
          {
            "id": "connect_timeout_seconds",
            "title": "Тайм-аут подключения",
