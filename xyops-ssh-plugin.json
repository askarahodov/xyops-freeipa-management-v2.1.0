{
  "type": "xypdf",
  "description": "SSH command Event Plugin for xyOps",
  "version": "1.0",
  "xyops": "1.0.83",
  "items": [
    {
      "type": "plugin",
      "data": {
        "id": "pmlc2ha8fssh1",
        "title": "SSH — Выполнить команду",
        "enabled": true,
        "type": "event",
        "command": "npx -y github:askarahodov/xyops-freeipa-management-v2.1.0#main",
        "script": "",
        "groups": [],
        "format": "",
        "params": [
          {
            "id": "action",
            "title": "Action",
            "type": "hidden",
            "value": "ssh_exec"
          },
          {
            "id": "host_port",
            "title": "Адрес и порт",
            "type": "text",
            "value": "",
            "required": true
          },
          {
            "id": "command",
            "title": "Команда",
            "type": "textarea",
            "value": "printf '=== %s ===\\n' \"$(hostname -f 2>/dev/null || hostname)\"; printenv | sort | awk -F= '{name=tolower($1); if (name ~ /(pass|token|secret|private|credential|auth|key)/) print $1 \"=[REDACTED]\"; else print $0}'",
            "required": true,
            "caption": "По умолчанию выводит переменные окружения SSH-сессии. Потенциально чувствительные значения маскируются."
          },
          {
            "id": "connect_timeout_seconds",
            "title": "Тайм-аут подключения",
            "type": "text",
            "variant": "number",
            "value": 15,
            "required": true,
            "caption": "Допустимый диапазон 1–300 секунд проверяется плагином при запуске."
          },
          {
            "id": "strict_host_key",
            "title": "Проверять ключ SSH-хоста",
            "type": "checkbox",
            "value": false
          },
          {
            "id": "host_fingerprint",
            "title": "SHA256 fingerprint ключа хоста",
            "type": "text",
            "value": "",
            "required": false
          }
        ],
        "notes": "Использует Secret Vault: SSH_USERNAME и SSH_PASSWORD либо SSH_PRIVATE_KEY.",
        "icon": "console-network-outline",
        "uid": "",
        "gid": "",
        "kill": "parent",
        "runner": false
      }
    }
  ]
}