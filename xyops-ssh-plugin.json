            "value": 15,
            "required": true,
            "caption": "Допустимый диапазон 1–300 секунд проверяется при запуске."
          },
          {
            "id": "strict_host_key",
            "title": "Проверять ключ SSH-хоста",
            "type": "checkbox",
            "value": false
          },
          {
            "id": "host_fingerprint",
            "title": "SHA256 fingerprint ключа хоста",
            "type": "text",
            "value": "",
            "required": false
          }
        ],
        "notes": "Подключается к хосту технической SSH-учёткой и выполняет scripts/create-local-user.sh через sudo. Создаёт локального пользователя, пароль, home, authorized_keys и sudo. Не меняет root и sshd_config.",
        "icon": "account-key-outline",
        "uid": "",
        "gid": "",
        "kill": "parent",
        "runner": false
      }
    },
