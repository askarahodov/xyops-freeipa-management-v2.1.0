                  "fields": [
                    {
                      "id": "action",
                      "title": "Action",
                      "type": "hidden",
                      "value": "disable_user"
                    }
                  ]
                },
                {
                  "id": "enableUser",
                  "title": "Включить пользователя",
                  "fields": [
                    {
                      "id": "action",
                      "title": "Action",
                      "type": "hidden",
                      "value": "enable_user"
                    }
                  ]
                },
                {
                  "id": "unlockUser",
                  "title": "Разблокировать пользователя",
                  "fields": [
                    {
                      "id": "action",
                      "title": "Action",
                      "type": "hidden",
                      "value": "unlock_user"
                    }
                  ]
                },
                {
                  "id": "listGroups",
                  "title": "Список групп",
                  "fields": [
                    {
                      "id": "action",
                      "title": "Action",
                      "type": "hidden",
                      "value": "list_groups"
                    },
                    {
                      "id": "search_criteria",
                      "title": "Поиск",
                      "type": "text",
                      "value": ""
                    },
                    {
                      "id": "list_limit",
                      "title": "Лимит",
                      "type": "text",
                      "variant": "number",
                      "value": 200,
                      "range": "1 - 10000 / 1",
                      "required": true
                    }
                  ]
                },
                {
                  "id": "syncDirectoryCache",
                  "title": "Синхронизировать меню",
                  "fields": [
                    {
                      "id": "action",
                      "title": "Action",
                      "type": "hidden",
                      "value": "sync_directory_cache"
                    },
                    {
                      "id": "list_limit",
                      "title": "Лимит",
                      "type": "text",
                      "variant": "number",
                      "value": 10000,
                      "range": "1 - 10000 / 1",
                      "required": true
                    }
                  ]
                },
                {
                  "id": "addUserToGroups",
                  "title": "Добавить пользователя в группы",
                  "fields": [
                    {
                      "id": "action",
                      "title": "Action",
                      "type": "hidden",
                      "value": "add_user_to_groups"
                    }
                  ]
                },
                {
                  "id": "removeUserFromGroups",
                  "title": "Удалить пользователя из групп",
                  "fields": [
                    {
                      "id": "action",
                      "title": "Action",
                      "type": "hidden",
                      "value": "remove_user_from_groups"
                    }
                  ]
                }
              ]
            }
          }
        ],
        "notes": "Основные операции. Пользователь и группы выбираются из кэша. Фильтр по группе — необязательный текст и применяется только к списку пользователей.",
        "icon": "users-cog",
        "uid": "",
        "gid": "",
        "kill": "parent",
        "runner": false
      }
