  "items": [
    {
      "type": "bucket",
      "data": {
        "id": "bfreeipacache",
        "title": "Кэш каталога FreeIPA",
        "enabled": true,
        "icon": "database-sync",
        "notes": "Заполняется операцией sync_directory_cache и действием Store Bucket."
      }
    },
    {
      "type": "plugin",
      "data": {
        "id": "pmlc2ha8fipa1",
        "title": "Управление FreeIPA",
        "enabled": true,
        "type": "event",
        "command": "npx -y github:askarahodov/xyops-freeipa-management-v2.1.0#main",
        "script": "",
        "groups": [],
        "format": "",
        "params": [
          {
            "id": "ipa_url",
            "title": "URL FreeIPA",
            "type": "text",
            "value": "https://ipa.example.local",
            "variant": "url",
            "required": true
          },
          {
            "id": "ca_cert_path",
            "title": "Сертификат CA FreeIPA",
            "type": "text",
            "value": "/etc/ipa/ca.crt",
            "required": false
          },
          {
            "id": "timeout_seconds",
            "title": "Тайм-аут",
            "type": "text",
            "variant": "number",
            "value": 30,
            "range": "1 - 300 / 1",
            "required": true
          },
          {
            "id": "insecure_tls",
            "title": "Отключить проверку TLS",
            "type": "checkbox",
            "value": false
          },
          {
            "id": "selection_group",
            "title": "Выбор из кэша FreeIPA",
